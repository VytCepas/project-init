name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  # Optimization: Only run CI when relevant files change
  # Uncomment and adjust paths as needed for your project

permissions:
  contents: read
  pull-requests: write

jobs:
  lint-and-test:
    name: Lint and test
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v6

{{#if python}}
      - name: Install uv
        uses: astral-sh/setup-uv@v8.1.0
        with:
          version: "0.11.7"
          enable-cache: true
          cache-dependency-glob: "pyproject.toml"
          python-version: "3.12"

      # CI invokes the same justfile recipes agents and humans use (PI-139),
      # so the command surface is defined exactly once.
      - name: Install just
        uses: extractions/setup-just@v4

      - name: Sync dev dependencies
        run: just setup

      - name: Lint
        run: just lint

      # Coverage gate (PI-138): activates automatically once pytest-cov is in
      # dev dependencies; runs plain tests until then. Tune --cov-fail-under
      # in the justfile's test-cov recipe to your project's baseline.
      - name: Tests — parallel, coverage-gated
        run: |
          if uv run python -c "import pytest_cov" 2>/dev/null; then
            just test-cov
          else
            echo "pytest-cov not installed — running without the coverage gate."
            echo "Add pytest-cov to dev dependencies to enable it."
            just test
          fi
{{/if python}}
{{#if node}}
      - name: Install Bun
        uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      # Lint/test invoke the same justfile recipes agents and humans use
      # (PI-139). Dependency install stays inline: the frozen-lockfile
      # fallback below is CI-specific logic that doesn't belong in a recipe.
      - name: Install just
        uses: extractions/setup-just@v4

      # Fresh scaffolds have no lockfile yet — fall back to a plain install.
      - name: Install dependencies
        run: |
          if [ -f bun.lock ] || [ -f bun.lockb ]; then
            bun install --frozen-lockfile
          else
            bun install
          fi

      - name: Lint
        run: just lint

      - name: Tests
        run: just test
{{/if node}}
{{#if go}}
      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      # The action installs + caches golangci-lint on CI; locally `just lint`
      # runs the same `golangci-lint run` against the same .golangci.yml.
      - name: Lint (golangci-lint)
        uses: golangci/golangci-lint-action@v6

      # Tests run via the justfile recipe agents and humans use (PI-139);
      # lint stays on the action above, which installs and caches the binary.
      - name: Install just
        uses: extractions/setup-just@v4

      - name: Tests
        run: just test
{{/if go}}

      - name: Post failure summary
        if: failure() && github.event_name == 'pull_request'
        env:
          GH_TOKEN: ${{ github.token }}
          RUN_URL: ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}
        run: |
          PR_NUMBER="${{ github.event.pull_request.number }}"
          FAILED_STEPS=$(cat <<'SUMMARY'
          Lint or tests failed in this run. Check the details and fix before re-pushing.
          SUMMARY
          )
          gh pr comment "$PR_NUMBER" --body "## CI failed

          **Run:** $RUN_URL

          To see what failed:
          \`\`\`bash
          gh run view --log-failed
          \`\`\`

          Fix the issues, then run \`.claude/scripts/push_branch.sh\` to re-trigger CI."

{{#if python}}
  # Optimization #2: Split heavyweight tests into separate job
  # Only run integration/smoke tests after fast lint+unit tests pass
  # Adjust this job based on your actual integration test needs
  integration-tests:
    name: Integration tests
    runs-on: ubuntu-24.04
    needs: lint-and-test
    # Optional: Only run on main branch or when tests change significantly
    # if: github.ref == 'refs/heads/main' || contains(github.event.pull_request.files[*].name, 'tests/')
    steps:
      - uses: actions/checkout@v6

      - name: Install uv
        uses: astral-sh/setup-uv@v8.1.0
        with:
          version: "0.11.7"
          enable-cache: true
          cache-dependency-glob: "pyproject.toml"

      - name: Set up Python
        run: uv python install 3.12

      - name: Sync dev dependencies
        run: uv sync --group dev

      # Check if integration tests directory exists before running
      # This prevents masking real test failures with "No integration tests" message
      - name: Run integration tests
        run: |
          if [ -d tests/integration/ ]; then
            uv run pytest tests/integration/ -v --tb=short
          else
            echo "No integration tests directory found (tests/integration/)"
            echo "Create tests/integration/ when you have integration tests to run"
          fi

  # Test-quality verification via mutation testing (PI-138). Mutmut is slow,
  # so it runs nightly, not per-PR. Uncomment to enable; requires mutmut in
  # dev dependencies and a [tool.mutmut] section in pyproject.toml.
  # mutation-tests:
  #   name: Mutation tests (mutmut)
  #   runs-on: ubuntu-24.04
  #   if: github.event_name == 'schedule'
  #   steps:
  #     - uses: actions/checkout@v6
  #     - uses: astral-sh/setup-uv@v8.1.0
  #       with:
  #         version: "0.11.7"
  #     - run: uv sync --group dev
  #     - run: uv run mutmut run
  # (also add to the top-level `on:` block:)
  #   schedule:
  #     - cron: "0 3 * * *"
{{/if python}}

  # ADR-007: agent-agnostic secret-scanning backstop. The pre-commit git hook
  # gives fast local feedback but is fail-open; this job is the hard gate.
  secret-scan:
    name: Secret scan (gitleaks)
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v6
        with:
          # Full history so leaked commits are caught, not just the latest diff
          fetch-depth: 0

      - uses: gitleaks/gitleaks-action@v3
        env:
          GITHUB_TOKEN: ${{ github.token }}
          # GITLEAKS_LICENSE is required only for organization-owned repos
          # (free key from gitleaks.io). Personal accounts need no license.
          GITLEAKS_LICENSE: ${{ secrets.GITLEAKS_LICENSE }}

# Optimization #3: Conditional job execution
# Example configurations for different scenarios (see full details in CLAUDE.md):
#
# Path filters: Only run CI when relevant files change
# Skip tests for docs-only changes: Use GitHub Actions conditional if statements
# Skip integration tests for PRs from forks: Use event filters
# See GitHub Actions documentation for complete conditionals syntax
