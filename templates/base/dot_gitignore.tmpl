# project-init runtime artifacts
.codex
.claude/scheduled_tasks.lock
.claude/.session_setup_stamp
.claude/settings.local.json
{{#if memory}}.claude/memory/.cache/
{{/if memory}}.claude/logs/
.claude/.local/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

{{#if node}}# Node
node_modules/
dist/
*.tsbuildinfo
npm-debug.log*
.npm/

{{/if node}}{{#if go}}# Go
/bin/
*.exe
*.test
*.out
vendor/

{{/if go}}{{#if rust}}# Rust
/target/
**/*.rs.bk

{{/if rust}}{{#if graphify}}# Graphify (derived graph artifacts; keep GRAPH_REPORT.md tracked)
graphify-out/*
!graphify-out/GRAPH_REPORT.md

{{/if graphify}}{{#if rag}}# cocoindex-code RAG index (derived sqlite-vec cache; never committed)
.cocoindex_code/

{{/if rag}}{{#if obsidian}}# Obsidian (vault workspace state only; keep notes tracked)
.claude/vault/.obsidian/workspace*
.claude/vault/.obsidian/cache
.claude/vault/.trash/

{{/if obsidian}}# OS / editor
.DS_Store
*.swp
{{#if vscode}}# Scaffolded editor config (--vscode) is shared; the rest stays personal.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/mcp.json
{{/if vscode}}{{#if vscode_off}}# .vscode is personal, except a generated MCP config meant to be shared (PI-366).
.vscode/*
!.vscode/mcp.json
{{/if vscode_off}}.idea/

# Secrets
.env
.env.local
*.key
