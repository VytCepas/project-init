{{#if python}}# mypy.ini — static type checking gates for project code (scaffolded by project-init).
# ruff lints; it does not type-check. `just typecheck` runs this against src/
# only — test code and agent infra (.claude/**) are out of scope by construction,
# the same way ruff.toml exempts them via per-file-ignores.
#
# python_version pins the typeshed/syntax baseline mypy checks against; keep it
# aligned with your pyproject.toml's requires-python floor.

[mypy]
python_version = 3.11
strict = True
warn_unused_configs = True
{{/if python}}
