{{#if go}}# .golangci.yml — quality gates for project code (scaffolded by project-init).
# Requires golangci-lint v2.5.0+ (godoclint is bundled since v2.5.0).
version: "2"

linters:
  default: standard
  enable:
    # Enforced doc comments on exported symbols.
    - revive
    # Doc-comment style/completeness checks.
    - godoclint
    # Cognitive complexity cap — mechanical guard against noodly code.
    - gocognit
    # Cyclomatic complexity cap — the direct analog to ruff's mccabe (C901).
    - cyclop
    # Duplicate-code detector.
    - dupl
    # Also explicit on top of the "standard" default set below, so the gate
    # doesn't silently depend on golangci-lint's default-set definition.
    - errcheck
    - govet
    - staticcheck
    # Security linter — Go's analog to ruff's S/bandit rules (PI-570).
    # Verified against a real weak-crypto (md5) violation.
    - gosec
  settings:
    revive:
      rules:
        - name: exported
    gocognit:
      # >15 usually means the function wants splitting.
      min-complexity: 15
    cyclop:
      # Mirrors ruff.toml's [lint.mccabe] max-complexity = 10.
      max-complexity: 10
    dupl:
      threshold: 100

formatters:
  enable:
    # Stricter than gofmt — also runs gofmt's rules plus extra style checks.
    - gofumpt
{{/if go}}