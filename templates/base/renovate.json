{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "schedule:weekly",
    "group:allNonMajor"
  ],
  "semanticCommits": "disabled",
  "commitMessagePrefix": "[nojira][chore]",
  "lockFileMaintenance": {
    "enabled": true
  }
}
