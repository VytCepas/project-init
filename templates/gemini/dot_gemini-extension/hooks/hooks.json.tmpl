{{#if gemini}}{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "github-command-guard",
            "type": "command",
            "command": ".claude/hooks/_py.sh .claude/hooks/agent_guard_adapter.py gemini",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
{{/if gemini}}